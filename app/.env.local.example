# ─── Supabase (ContractHub project — separate from MaidHub) ───────────────────
# Create a new project at https://supabase.com and paste the values from
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_CONTRACTHUB_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-contracthub-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-contracthub-service-role-key-here

# ─── Square (subscription billing — use a separate sandbox app for ContractHub) ─
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_PLAN_VARIATION_ID=your-plan-variation-id

# ─── Site URL (update to your production domain on deploy) ───────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001
